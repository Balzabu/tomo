{
  "expo": {
    "name": "Tomo",
    "slug": "tomo",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tomo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.balzabu.tomo"
    },
    "android": {
      "package": "io.balzabu.tomo",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-icon-back.png",
        "monochromeImage": "./assets/adaptive-icon-mono.png",
        "backgroundColor": "#536dfe"
      },
      "permissions": [
        "CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Tomo uses the camera to scan book barcodes (ISBN)."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Tomo accesses your photos so you can choose a book cover."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-localization",
      "./plugins/withAndroidLintFix",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "CurrentlyReading",
              "label": "Tomo · Reading",
              "description": "The book you're reading, with progress and stats",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/widgets/currentlyreading.png",
              "widgetFeatures": "reconfigurable",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "QuickStart",
              "label": "Tomo · Start session",
              "description": "Start a reading session by picking a book",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "previewImage": "./assets/widgets/quickstart.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "StreakGoal",
              "label": "Tomo · Streak & goal",
              "description": "Your day streak and today's goal",
              "minWidth": "140dp",
              "minHeight": "140dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/widgets/streakgoal.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Heatmap",
              "label": "Tomo · Calendar",
              "description": "Your reading calendar",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/widgets/heatmap.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ]
    ],
    "locales": {
      "en": "./locales/en.json",
      "it": "./locales/it.json",
      "es": "./locales/es.json",
      "fr": "./locales/fr.json",
      "de": "./locales/de.json",
      "pt": "./locales/pt.json"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
